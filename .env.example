# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=

# ============================================
# MINIO OBJECT STORAGE CONFIGURATION
# ============================================
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_USE_SSL=False
MINIO_BUCKET_TEMP=
MINIO_BUCKET_OUTPUT=media-output
MINIO_BUCKET_THUMBS=media-thumbs

# ============================================
# FFMPEG CONFIGURATION
# ============================================
# Linux/Mac:
# FFMPEG_PATH=/usr/bin/ffmpeg
# Windows (with ffmpeg installed):
FFMPEG_PATH=ffmpeg

# ============================================
# LOG CONFIGURATION
# ============================================
LOG_LEVEL=INFO
DEBUG=False

# ============================================
# UPLOAD CONFIGURATION
# ============================================
MAX_CHUNK_SIZE=5242880 # 5MB per chunk
MAX_FILE_SIZE=524288000 # 500MB max file size
CHUNK_UPLOAD_EXPIRY=86400 # 24 hours

# ============================================
# CRON WORKER CONFIGURATION
# ============================================
WORKER_INTERVAL=30 # Check every 30 seconds
PROCESSING_TIMEOUT=600 # 10 minutes processing timeout
STUCK_JOB_THRESHOLD=600 # 10 minutes before marking as stuck
MAX_RETRIES=3 # Max 3 retry attempts
WORKER_CONCURRENT_JOBS=5 # Process 5 jobs in parallel

# ============================================
# API SERVER CONFIGURATION
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ============================================
# CORS CONFIGURATION
# ============================================
# Development: *
# Production: http://localhost:3000,http://localhost:5173
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=False
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# ============================================
# SECURITY CONFIGURATION
# ============================================
JWT_SECRET_KEY=your-very-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# FFMPEG PROCESSING CONFIGURATION
# ============================================
# Thumbnail settings
THUMB_WIDTH=320
THUMB_HEIGHT=180
THUMB_SEEK_SECONDS=5

# Video compression settings
VIDEO_CODEC=libx264
VIDEO_CRF=23 # Quality: 0-51 (lower = better)
AUDIO_CODEC=aac
AUDIO_BITRATE=128k

# ============================================
# APPLICATION ENVIRONMENT
# ============================================
ENVIRONMENT=development

